# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration (Frontend - Anonymous Key)
# These are safe to expose in frontend code (anonymous keys only)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anonymous-key-here

# Supabase Configuration (Backend - Service Role Key)
# ⚠️ KEEP THESE PRIVATE - Never expose in frontend code
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API Configuration
API_URL=http://localhost:3000
NODE_ENV=development

# Optional: Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure_password_here
